# MixMaster backend environment template
# Copy to .env and adjust values for your machine or environment.

SPRING_PROFILES_ACTIVE=local

# Server
SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8080
SERVER_ERROR_INCLUDE_MESSAGE=never
SERVER_TOMCAT_ACCESSLOG_ENABLED=true
SERVER_TOMCAT_ACCESSLOG_PATTERN=%a "%r" %s %b %D

# Database
DB_URL=jdbc:mariadb://localhost:3306/mixmaster?createDatabaseIfNotExist=true
# DB_URL=jdbc:mariadb://localhost:3307/mixmaster?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=root
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=5
DB_POOL_TIMEOUT_MS=10000
DB_POOL_VALIDATION_TIMEOUT_MS=5000
DB_POOL_IDLE_TIMEOUT_MS=600000
DB_POOL_MAX_LIFETIME_MS=1800000

# Hibernate / Flyway
HIBERNATE_DDL_AUTO=validate
HIBERNATE_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
SPRING_FLYWAY_ENABLED=true

# Redis / Cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=3000
SPRING_CACHE_TYPE=simple

# Logging
LOG_LEVEL_SPRING=INFO
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_HIBERNATE_SQL=WARN
LOG_LEVEL_APP=INFO

# Multitenancy headers
MIXMASTER_TENANT_HEADER=X-Tenant-Key
MIXMASTER_BRAND_HEADER=X-Brand-Key
MIXMASTER_BRANCH_HEADER=X-Branch-Key

# Allowed origins
MIXMASTER_CORS_ORIGIN_0=http://localhost:4200
MIXMASTER_CORS_ORIGIN_1=http://localhost:4201
MIXMASTER_CORS_ORIGIN_2=http://localhost:4202
MIXMASTER_CORS_ORIGIN_3=http://localhost:4300

# Bootstrap users
MIXMASTER_BOOTSTRAP_ENABLED=false
MIXMASTER_BOOTSTRAP_CONSUMER_USERNAME=consumer@local
MIXMASTER_BOOTSTRAP_CONSUMER_PASSWORD=consumer-local
MIXMASTER_BOOTSTRAP_TENANT_USERNAME=tenant@local
MIXMASTER_BOOTSTRAP_TENANT_PASSWORD=tenant-local
MIXMASTER_BOOTSTRAP_PLATFORM_USERNAME=portal@local
MIXMASTER_BOOTSTRAP_PLATFORM_PASSWORD=portal-local

# Token settings
MIXMASTER_TOKEN_ENABLED=false
MIXMASTER_TOKEN_ISSUER=mixmaster.local
MIXMASTER_TOKEN_ACCESS_TTL=PT15M
MIXMASTER_TOKEN_REFRESH_TTL=P30D
MIXMASTER_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Rate limiting
MIXMASTER_RATE_LIMIT_ENABLED=true
MIXMASTER_RATE_LIMIT_LOGIN_PER_MINUTE=20
MIXMASTER_RATE_LIMIT_WRITE_PER_MINUTE=120
MIXMASTER_RATE_LIMIT_STATUS_PER_MINUTE=240

# Audit
MIXMASTER_AUDIT_ENABLED=true
