{
  "name": "saas-admin",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "link:shared-deps": "node ../scripts/link-shared-deps.mjs saas-admin",
    "postinstall": "npm run link:shared-deps",
    "prestart": "npm run link:shared-deps",
    "start": "ng serve",
    "start:default": "ng serve --port 4202",
    "prebuild": "npm run link:shared-deps",
    "build": "ng build",
    "prewatch": "npm run link:shared-deps",
    "watch": "ng build --watch --configuration development",
    "pretest": "npm run link:shared-deps",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.11.1",
  "dependencies": {
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.0",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
