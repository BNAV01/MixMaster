{
  "name": "mixmaster-frontend-workspace",
  "private": true,
  "scripts": {
    "link-shared-deps": "node ./scripts/link-shared-deps.mjs",
    "postinstall": "npm run link-shared-deps",
    "build:consumer": "npm run build --prefix consumer-web",
    "build:tenant": "npm run build --prefix tenant-console",
    "build:saas": "npm run build --prefix saas-admin",
    "build:all": "npm run build:consumer && npm run build:tenant && npm run build:saas"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/build": "^21.2.2",
    "@angular/cdk": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "express": "^5.1.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.1",
    "typescript": "~5.9.2",
    "zone.js": "~0.16.0"
  }
}
